Grammar

    0 $accept: program "end of file"

    1 program: exp
    2        | chunks

    3 exp: "integer"
    4    | "string"
    5    | "nil"
    6    | "identifier"
    7    | "identifier" "(" exps.0 ")"
    8    | "(" exps.0 ")"
    9    | lvalue ":=" exp
   10    | "if" exp "then" exp
   11    | "if" exp "then" exp "else" exp
   12    | "while" exp "do" exp
   13    | "for" "identifier" ":=" exp "to" exp "do" exp
   14    | "break"
   15    | "let" chunks "in" exps.0 "end"
   16    | exp "+" exp
   17    | exp "-" exp
   18    | exp "*" exp
   19    | exp "/" exp
   20    | exp "=" exp
   21    | exp "<>" exp
   22    | exp "<" exp
   23    | exp "<=" exp
   24    | exp ">" exp
   25    | exp ">=" exp
   26    | "-" exp
   27    | exp "&" exp
   28    | exp "|" exp
   29    | "identifier" "[" exp "]" "of" exp
   30    | "identifier" "{" fieldinits "}"
   31    | "_exp" "(" "integer" ")"

   32 lvalue: "identifier"
   33       | lvalue "[" exp "]"
   34       | lvalue "." "identifier"

   35 exps.0: ε
   36       | exps

   37 exps: exp
   38     | exps ";" exp

   39 fieldinits: ε
   40           | fieldinits.1

   41 fieldinits.1: fieldinit
   42             | fieldinits.1 "," fieldinit

   43 fieldinit: "identifier" "=" exp

   44 chunks: ε
   45       | tychunk chunks
   46       | funchunk chunks
   47       | varchunk chunks

   48 funchunk: fundec
   49         | fundec funchunk

   50 fundec: "function" "identifier" "(" funargs ")" typeid.opt "=" exp

   51 funargs: ε
   52        | funargs.1

   53 funargs.1: "identifier" ":" typeid
   54          | funargs.1 "," "identifier" ":" typeid

   55 typeid.opt: ε
   56           | ":" typeid

   57 varchunk: vardec

   58 vardec: "var" "identifier" ":=" exp
   59       | "var" "identifier" ":" typeid ":=" exp

   60 tychunk: tydec
   61        | tydec tychunk

   62 tydec: "type" "identifier" "=" ty

   63 ty: typeid
   64   | "{" tyfields "}"
   65   | "array" "of" typeid

   66 tyfields: ε
   67         | tyfields.1

   68 tyfields.1: tyfield
   69           | tyfields.1 "," tyfield

   70 tyfield: "identifier" ":" typeid

   71 typeid: "identifier"
   72       | "_namety" "(" "integer" ")"


